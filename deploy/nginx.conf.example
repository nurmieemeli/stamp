# Reverse proxy for Stamp (Next.js on port 3000, via PM2/systemd).
# Copy to /etc/nginx/sites-available/stamp, symlink into sites-enabled,
# then run: sudo certbot --nginx -d stamp.rip
# (certbot rewrites this into an HTTPS block automatically — auth won't work
# without HTTPS, since NextAuth's session cookie is marked Secure in production).

server {
    listen 80;
    listen [::]:80;
    server_name stamp.rip;

    # Avatar uploads are capped at 8MB server-side (see next.config.ts) —
    # nginx's own 1MB default would reject the upload before Next ever sees it.
    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
