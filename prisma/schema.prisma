// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  username                String                   @unique
  createdAt               DateTime                 @default(now())
  // No column-level default (SQLite disallows non-constant defaults on
  // ADD COLUMN) — the migration backfills existing rows to now() directly,
  // and every db.user.create() call explicitly sets this field.
  emailVerifiedAt         DateTime?
  isPro                   Boolean                  @default(false)
  // Nullable rather than a "" default so it's safe to add @unique later
  // without an empty-string collision (SQLite unique indexes treat every ""
  // as equal, but allow multiple NULLs).
  stripeCustomerId        String?
  proPurchasedAt          DateTime?
  profile                 Profile?
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  invitesUsed             InviteCode[]             @relation("InviteCodeUser")
  purchases               Purchase[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model InviteCode {
  id             String    @id @default(cuid())
  code           String    @unique
  createdByEmail String
  createdAt      DateTime  @default(now())
  usedAt         DateTime?
  usedByUserId   String?
  usedByUser     User?     @relation("InviteCodeUser", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([usedByUserId])
}

model Profile {
  id              String         @id @default(cuid())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String         @unique
  displayName     String
  bio             String         @default("")
  trackTitle      String         @default("")
  trackArtist     String         @default("")
  trackPreviewUrl String         @default("")
  trackArtworkUrl String         @default("")
  trackUrl        String         @default("")
  avatarUrl       String         @default("")
  palette         String         @default("amber")
  // Hex accent override, Pro-only — "" means unset, fall back to the
  // selected palette's own accent.
  customAccent    String         @default("")
  viewCount       Int            @default(0)
  links           Link[]
  badges          ProfileBadge[]
}

model Link {
  id        String  @id @default(cuid())
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  platform  String
  value     String
  order     Int     @default(0)

  @@index([profileId])
}

model Badge {
  id       String         @id @default(cuid())
  key      String         @unique
  label    String
  color    String         @default("#6FCF7F")
  icon     String         @default("check")
  profiles ProfileBadge[]
}

model ProfileBadge {
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   String
  grantedAt DateTime @default(now())

  @@id([profileId, badgeId])
  @@index([badgeId])
}

model Purchase {
  id     String @id @default(cuid())
  // onDelete: Cascade matches every other audit/join table in this schema —
  // note that means deleting a User destroys their payment history too.
  // There's no account-deletion flow today, so this is moot for now, but
  // flag it before one gets built.
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  stripeCheckoutSessionId String   @unique
  // Kept even though nothing reads it yet — the natural handle for a future
  // refund/chargeback webhook without a second migration.
  stripePaymentIntentId   String   @default("")
  amountTotal             Int
  currency                String
  createdAt               DateTime @default(now())

  @@index([userId])
}
